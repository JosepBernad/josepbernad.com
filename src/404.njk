---
layout: base.njk
title: Page Not Found
permalink: /404.html
eleventyExcludeFromCollections: true
---

<script>
  // Vercel serves /404.html for any not-found path, so detect the URL prefix
  // and set html[lang] before main.js applies translations and before the
  // header links are rewritten below.
  (function () {
    var path = location.pathname;
    var lang = 'en';
    var prefix = '';
    if (path.indexOf('/es/') === 0 || path === '/es') { lang = 'es'; prefix = '/es'; }
    else if (path.indexOf('/ca/') === 0 || path === '/ca') { lang = 'ca'; prefix = '/ca'; }
    document.documentElement.lang = lang;
    // Strip the language prefix so we can re-prefix per switcher link.
    var basePath = prefix ? path.slice(prefix.length) : path;
    if (!basePath || basePath.charAt(0) !== '/') basePath = '/' + basePath;
    var search = location.search || '';
    var hash = location.hash || '';
    document.addEventListener('DOMContentLoaded', function () {
      // Language switcher: point each link at the same unknown path under its own locale.
      document.querySelectorAll('.lang-switcher .lang-link').forEach(function (a) {
        var thisLang = a.getAttribute('hreflang');
        var target;
        if (thisLang === 'en') target = basePath;
        else if (thisLang === 'ca') target = '/ca' + basePath;
        else if (thisLang === 'es') target = '/es' + basePath;
        else return;
        a.href = target + search + hash;
        a.classList.toggle('active', lang === thisLang);
      });
      // "Back to home" link on the error card.
      var back = document.querySelector('.error-link');
      if (back) back.href = (prefix || '') + '/';
      // Header "Josep Bernad" link and primary nav: rewrite to the language-appropriate prefix.
      var nameLink = document.querySelector('.header-name-link');
      if (nameLink) nameLink.href = (prefix || '') + '/';
      document.querySelectorAll('.site-nav__link').forEach(function (link) {
        var href = link.getAttribute('href') || '';
        var stripped = href.replace(/^\/(es|ca)(?=\/|$)/, '');
        link.href = (prefix || '') + (stripped || '/');
      });
    });
  })();
</script>

<div class="error-page">
  <h1 class="error-code">404</h1>
  <p class="error-message" data-i18n="error.notFound">Page not found</p>
  <p class="error-description" data-i18n="error.notFoundDesc">The page you're looking for doesn't exist or has been moved.</p>
  <a href="/" class="error-link" data-i18n="error.backHome">← Back to Home</a>
</div>


