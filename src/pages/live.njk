---
pagination:
  data: languages.list
  size: 1
  alias: lang
permalink: "{{ lang.prefix }}/live/"
layout: base.njk
pageId: live
eleventyComputed:
  currentLang: "{{ lang.code }}"
  currentPrefix: "{{ lang.prefix }}"
  langPrefix: "{{ lang.prefix }}"
---

{% set s = live.strings[currentLang] %}
{% set upcoming = live.upcoming | upcomingOnly %}
{% set past = live.past | pastDesc %}

<div class="section-container page-hero-wrap">
  <div class="contact-hero">
    <p class="contact-eyebrow">{{ s.hero.eyebrow }}</p>
    <h1 class="contact-hero-title">{{ s.hero.title | safe }}</h1>
    <p class="contact-hero-sub">{{ s.hero.sub | safe }}</p>
  </div>
</div>

<div class="section-container live-container">
  <p class="live-section-label">{{ s.upcoming }}</p>

  {% if upcoming.length %}
  <div class="live-list">
    {% for ev in upcoming %}
    <article class="live-card">
      <div class="live-date">
        <span class="day">{{ ev.date | liveDay }}</span>
        <span class="month">{{ ev.date | liveMonth(currentLang) }}</span>
        <span class="year">{{ ev.date | liveYear }}</span>
      </div>
      <div class="live-info">
        <h3 class="live-event">{{ ev.event[currentLang] if ev.event[currentLang] else ev.event }}</h3>
        <p class="live-venue">{{ ev.venue[currentLang] }}</p>
        <p class="live-desc">{{ ev.description[currentLang] | safe }}</p>
      </div>
      <div class="live-meta">
        <span class="live-time">{{ ev.time }}</span>
        <a class="live-map" href="{{ ev.map }}" target="_blank" rel="noopener" aria-label="{{ s.map }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          {{ s.map }}
        </a>
      </div>
    </article>
    {% endfor %}
  </div>
  {% else %}
  <div class="live-empty">
    <p class="live-empty-title">{{ s.emptyTitle }}</p>
    <p class="live-empty-body">{{ s.emptyBody }}</p>
    <div class="socials-wrapper" data-nosnippet>
      <div class="socials">
        <a href="https://www.instagram.com/djosepbernad/" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 50 50" fill="currentColor"><path d="M 16 3 C 8.83 3 3 8.83 3 16 L 3 34 C 3 41.17 8.83 47 16 47 L 34 47 C 41.17 47 47 41.17 47 34 L 47 16 C 47 8.83 41.17 3 34 3 L 16 3 z M 37 11 C 38.1 11 39 11.9 39 13 C 39 14.1 38.1 15 37 15 C 35.9 15 35 14.1 35 13 C 35 11.9 35.9 11 37 11 z M 25 14 C 31.07 14 36 18.93 36 25 C 36 31.07 31.07 36 25 36 C 18.93 36 14 31.07 14 25 C 14 18.93 18.93 14 25 14 z M 25 16 C 20.04 16 16 20.04 16 25 C 16 29.96 20.04 34 25 34 C 29.96 34 34 29.96 34 25 C 34 20.04 29.96 16 25 16 z"/></svg></a>
        <a href="https://soundcloud.com/djosepbernad" target="_blank" rel="noopener noreferrer" aria-label="SoundCloud"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 208.952 1048.713 581.696" fill="currentColor"><path d="M0 686.216c0 13.014 4.718 22.854 14.152 29.524 9.435 6.669 19.52 9.027 30.256 7.076 10.085-1.952 17.161-5.531 21.229-10.736 4.066-5.205 6.1-13.827 6.1-25.864v-141.52c0-10.086-3.497-18.626-10.492-25.62-6.994-6.995-15.534-10.492-25.62-10.492-9.76 0-18.137 3.497-25.132 10.492C3.498 526.07 0 534.61 0 544.696v141.52zm112.24 60.512c0 9.436 3.335 16.511 10.004 21.229 6.67 4.718 15.21 7.076 25.62 7.076 10.736 0 19.438-2.359 26.108-7.076 6.669-4.717 10.004-11.793 10.004-21.229V416.84c0-9.76-3.498-18.138-10.492-25.132-6.995-6.994-15.535-10.492-25.62-10.492-9.76 0-18.138 3.498-25.132 10.492-6.995 6.995-10.492 15.372-10.492 25.132v329.888zm111.752 15.616c0 9.435 3.416 16.511 10.248 21.229 6.832 4.717 15.616 7.076 26.353 7.076 10.41 0 18.95-2.359 25.619-7.076 6.67-4.718 10.005-11.794 10.005-21.229V461.248c0-10.085-3.498-18.707-10.492-25.864-6.995-7.157-15.372-10.735-25.132-10.735-10.086 0-18.707 3.578-25.864 10.735s-10.736 15.779-10.736 25.864v301.096zm112.24 1.464c0 17.894 12.037 26.841 36.112 26.841 24.074 0 36.111-8.947 36.111-26.841v-488c0-27.328-8.296-42.781-24.888-46.36-10.736-2.603-21.31.488-31.72 9.272-10.411 8.784-15.616 21.146-15.616 37.088v488zm114.193 14.152V247.016c0-16.917 5.042-27.002 15.128-30.256 21.797-5.205 43.432-7.808 64.904-7.808 49.775 0 96.136 11.712 139.079 35.136 42.944 23.424 77.674 55.388 104.188 95.892 26.515 40.505 41.887 85.156 46.116 133.957 19.845-8.459 40.991-12.688 63.439-12.688 45.547 0 84.506 16.104 116.876 48.312 32.371 32.209 48.557 70.923 48.557 116.145 0 45.547-16.186 84.424-48.557 116.632-32.37 32.208-71.166 48.312-116.388 48.312l-424.56-.488c-2.929-.976-5.125-2.766-6.589-5.368s-2.193-4.882-2.193-6.834z"/></svg></a>
      </div>
    </div>
  </div>
  {% endif %}

  {% if past.length %}
  <p class="live-section-label live-section-label--past">{{ s.past }}</p>
  <div class="live-list live-list--past">
    {% for ev in past %}
    <article class="live-card is-past">
      <div class="live-date">
        <span class="day">{{ ev.date | liveDay }}</span>
        <span class="month">{{ ev.date | liveMonth(currentLang) }}</span>
        <span class="year">{{ ev.date | liveYear }}</span>
      </div>
      <div class="live-info">
        <h3 class="live-event">{{ ev.event[currentLang] if ev.event[currentLang] else ev.event }}</h3>
        <p class="live-venue">{{ ev.venue[currentLang] }}</p>
      </div>
      <div class="live-meta"><span class="live-time">{{ ev.time }}</span></div>
    </article>
    {% endfor %}
  </div>
  {% endif %}
</div>

<section class="home-panoramic">
  <img src="/images/JosepBernad-Panoramic.webp" alt="Josep Bernad" loading="lazy">
  <div class="home-panoramic-overlay" id="newsletter-banner">
    <p class="newsletter-text" data-i18n="newsletter.cta">Stay Updated</p>
    <form class="newsletter-form" id="newsletter-form">
      <input type="email" name="EMAIL" placeholder="email@example.com" data-i18n-placeholder="newsletter.placeholder" required>
      <div style="position: absolute; left: -5000px;" aria-hidden="true">
        <input type="text" name="b_ec19e426d1a78e9baa513bfaf_7a99017863" tabindex="-1" value="">
      </div>
      <button type="submit" data-i18n="newsletter.subscribe">Subscribe</button>
    </form>
    <p class="newsletter-status" id="newsletter-status"></p>
  </div>
</section>
