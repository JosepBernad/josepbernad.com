---
pagination:
  data: languages.list
  size: 1
  alias: lang
permalink: "{{ lang.prefix }}/contact/"
layout: base.njk
pageId: contact
showClaim: false
showName: true
sectionName: Contact
eleventyComputed:
  currentLang: "{{ lang.code }}"
  currentPrefix: "{{ lang.prefix }}"
  lang: "{{ lang.code }}"
  langPrefix: "{{ lang.prefix }}"
---

<div class="section-container contact-wrap">

  {# Editorial header #}
  <div class="contact-hero">
    <p class="contact-eyebrow" data-i18n="contact.eyebrow">{{ contact[currentLang].eyebrow }}</p>
    <h1 class="contact-hero-title" data-i18n-html="contact.heroTitle">{{ contact[currentLang].heroTitle | safe }}</h1>
    <p class="contact-hero-sub" data-i18n-html="contact.heroSub">{{ contact[currentLang].heroSub | safe }}</p>
  </div>

  {# Split card: details (left) + form (right) #}
  <div class="contact-card">

    <aside class="contact-details">
      <div class="contact-detail-row">
        <p class="contact-row-label" data-i18n="contact.labelEmail">{{ contact[currentLang].labelEmail }}</p>
        <p class="contact-row-value">
          <a id="contact-email-link"
             href="&#109;&#97;&#105;&#108;&#116;&#111;&#58;&#104;&#105;&#64;&#106;&#111;&#115;&#101;&#112;&#98;&#101;&#114;&#110;&#97;&#100;&#46;&#99;&#111;&#109;"
             data-i18n-html="contact.emailAddress">{{ contact[currentLang].emailAddress | safe }}</a>
        </p>
      </div>

      <div class="contact-detail-row">
        <p class="contact-row-label" data-i18n="contact.labelInstagram">{{ contact[currentLang].labelInstagram }}</p>
        <p class="contact-row-value">
          <a href="https://www.instagram.com/djosepbernad/" target="_blank" rel="noopener">@djosepbernad</a>
        </p>
      </div>

      <div class="contact-detail-row">
        <p class="contact-row-label" data-i18n="contact.labelElsewhere">{{ contact[currentLang].labelElsewhere }}</p>
        <div class="contact-socials">
