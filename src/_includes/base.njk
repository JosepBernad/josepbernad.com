<!DOCTYPE html>
<html lang="{{ urlLang | default('en') }}" {% if pageId and pageId != 'home' %}data-section{% endif %}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  {# Language-prefix-stripped path, used by hreflang links below and by the language switcher in the header. #}
  {% set pagePath = page.url | replace('/es/', '/') | replace('/ca/', '/') %}
  {% if pagePath == '/es' or pagePath == '/ca' %}{% set pagePath = '/' %}{% endif %}

  {# Get SEO data for current page and language #}
  {% set currentLang = urlLang | default('en') %}
  {% set pageKey = pageId | default('home') %}
  {% set seoData = seo[pageKey][currentLang] if seo[pageKey] and seo[pageKey][currentLang] else seo.home.en %}

  {# Per-page Open Graph image. Falls back to the site default. #}
  {% set ogImageWidth = "1200" %}
  {% set ogImageHeight = "630" %}
  {% set ogImageUrl = "https://josepbernad.com/images/og-image.jpg" %}
  {% if pageKey == 'films' and films.items[0] %}
    {% set ogImageUrl = "https://img.youtube.com/vi/" + films.items[0].videoId + "/maxresdefault.jpg" %}
    {% set ogImageWidth = "1280" %}
    {% set ogImageHeight = "720" %}
  {% elif pageKey == 'about' %}
    {% set ogImageUrl = "https://josepbernad.com/images/about.webp" %}
    {% set ogImageWidth = "2048" %}
    {% set ogImageHeight = "1150" %}
  {% elif pageKey == 'presskit' %}
    {% set ogImageUrl = "https://josepbernad.com/images/JosepBernad-Panoramic.webp" %}
    {% set ogImageWidth = "2660" %}
    {% set ogImageHeight = "1140" %}
  {% endif %}

  {# og:type: profile for the about page (a person), website otherwise. #}
  {% if pageKey == 'home' %}{% set ogType = "website" %}
  {% elif pageKey == 'about' %}{% set ogType = "profile" %}
  {% else %}{% set ogType = "website" %}{% endif %}

  <!-- SEO Title -->
  <title>{{ seoData.title }}</title>

  <!-- Meta Description -->
  <meta name="description" content="{{ seoData.description }}">

  <!-- Canonical URL -->
  <link rel="canonical" href="https://josepbernad.com{{ page.url }}">

  <!-- Hreflang Tags for Multilingual SEO -->
  <link rel="alternate" hreflang="en" href="https://josepbernad.com{{ pagePath }}" />
  <link rel="alternate" hreflang="es" href="https://josepbernad.com/es{{ pagePath }}" />
  <link rel="alternate" hreflang="ca" href="https://josepbernad.com/ca{{ pagePath }}" />
  <link rel="alternate" hreflang="x-default" href="https://josepbernad.com{{ pagePath }}" />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="{{ ogType }}">
  <meta property="og:url" content="https://josepbernad.com{{ page.url }}">
  <meta property="og:title" content="{{ seoData.title }}">
  <meta property="og:description" content="{{ seoData.description }}">
  <meta property="og:image" content="{{ ogImageUrl }}">
  <meta property="og:image:width" content="{{ ogImageWidth }}">
  <meta property="og:image:height" content="{{ ogImageHeight }}">
  <meta property="og:image:alt" content="Josep Bernad, DJ and Musician from Barcelona and Mallorca">
  <meta property="og:locale" content="{% if currentLang == 'es' %}es_ES{% elif currentLang == 'ca' %}ca_ES{% else %}en_US{% endif %}">
  {% if currentLang != 'en' %}<meta property="og:locale:alternate" content="en_US">{% endif %}
  {% if currentLang != 'es' %}<meta property="og:locale:alternate" content="es_ES">{% endif %}
  {% if currentLang != 'ca' %}<meta property="og:locale:alternate" content="ca_ES">{% endif %}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content="https://josepbernad.com{{ page.url }}">
  <meta name="twitter:title" content="{{ seoData.title }}">
  <meta name="twitter:description" content="{{ seoData.description }}">
  <meta name="twitter:image" content="{{ ogImageUrl }}">

  <!-- Additional SEO -->
  <meta name="author" content="Josep Bernad">
  <meta name="robots" content="index, follow">
  
  <!-- Theme bootstrap: set data-theme before paint to avoid FOUC on the theme toggle. -->
  <script>
    (function () {
      try {
        var saved = localStorage.getItem('theme-preference');
        var theme = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      } catch (_) {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>

  <!-- Favicon -->
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <link rel="icon" id="favicon" href="/favicon-light.svg" type="image/svg+xml" sizes="any">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  
  <!-- Preload background images based on color scheme preference -->
  <link rel="preload" as="image" href="/images/bg-light-mobile.webp" media="(max-width: 767px) and (prefers-color-scheme: light)">
  <link rel="preload" as="image" href="/images/bg-light-desktop.webp" media="(min-width: 768px) and (prefers-color-scheme: light)">
  <link rel="preload" as="image" href="/images/bg-dark-mobile.webp" media="(max-width: 767px) and (prefers-color-scheme: dark)">
  <link rel="preload" as="image" href="/images/bg-dark-desktop.webp" media="(min-width: 768px) and (prefers-color-scheme: dark)">
  
  <!-- Fonts (self-hosted Sedan, see /css/styles.css @font-face) -->
  <link rel="preload" as="font" type="font/woff2" href="/css/fonts/sedan-regular-latin.woff2" crossorigin>

  <!-- Styles -->
  <link rel="stylesheet" href="/css/styles.css">

  {# Vidstack is loaded lazily on the first film-card click — see video-modal.njk. #}
  
  <!-- Structured Data (JSON-LD) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": "https://josepbernad.com/#website",
        "url": "https://josepbernad.com",
        "name": "Josep Bernad",
        "description": "Musician and DJ from Mallorca based in Barcelona",
        "inLanguage": ["en", "es", "ca"]
      },
      {
        "@type": "MusicGroup",
        "@id": "https://josepbernad.com/#musician",
        "name": "Josep Bernad",
        "url": "https://josepbernad.com",
        "logo": "https://josepbernad.com/images/og-image.jpg",
        "image": "https://josepbernad.com/images/about.webp",
        "description": "Musician and DJ from Mallorca based in Barcelona. House music, live sets, and DJ performances.",
        "genre": ["House", "Electronic", "Deep House"],
        "foundingLocation": {
          "@type": "Place",
          "name": "Mallorca, Spain"
        },
        "location": {
          "@type": "Place",
          "name": "Barcelona, Spain"
        },
        "sameAs": [
          "https://www.instagram.com/djosepbernad/",
          "https://www.youtube.com/@JosepBernad",
          "https://open.spotify.com/artist/1f320LpftKzOM47I0RgMfJ",
          "https://soundcloud.com/djosepbernad",
          "https://www.linkedin.com/in/josepbernad/",
          "https://github.com/JosepBernad"
        ],
        "member": {
          "@type": "Person",
          "name": "Josep Bernad",
          "jobTitle": "Musician, DJ",
          "url": "https://josepbernad.com/about/"
        }
      },
      {
        "@type": "SiteNavigationElement",
        "@id": "https://josepbernad.com/#navigation",
        "name": "Main Navigation",
        "hasPart": [
          {
            "@type": "WebPage",
            "name": "Films",
            "description": "Watch live sets and DJ performances by Josep Bernad",
            "url": "https://josepbernad.com/films/"
          },
          {
            "@type": "WebPage",
            "name": "About",
            "description": "Learn about Josep Bernad, musician, DJ, and multi-instrumentalist",
            "url": "https://josepbernad.com/about/"
          },
          {
            "@type": "WebPage",
            "name": "Contact",
            "description": "Get in touch with Josep Bernad for bookings and collaborations",
            "url": "https://josepbernad.com/contact/"
          }
        ]
      }
    ]
  }
  </script>

  {# Per-page structured data. Multiple JSON-LD blocks are valid. #}
  {% if pageKey != 'home' %}
  {% set breadcrumbLabels = {
    'films': { 'en': 'Films', 'es': 'Films', 'ca': 'Films' },
    'about': { 'en': 'About', 'es': 'Sobre mí', 'ca': 'Sobre mi' },
    'contact': { 'en': 'Contact', 'es': 'Contacto', 'ca': 'Contacte' },
    'live': { 'en': 'Live', 'es': 'En vivo', 'ca': 'En directe' },
    'presskit': { 'en': 'Press Kit', 'es': 'Press Kit', 'ca': 'Press Kit' }
  } %}
  {% set homeLabels = { 'en': 'Home', 'es': 'Inicio', 'ca': 'Inici' } %}
  {% set crumbLabel = breadcrumbLabels[pageKey][currentLang] if breadcrumbLabels[pageKey] else seoData.title %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": {{ homeLabels[currentLang] | dump | safe }},
        "item": "https://josepbernad.com{{ langPrefix }}/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ crumbLabel | dump | safe }},
        "item": "https://josepbernad.com{{ page.url }}"
      }
    ]
  }
  </script>
  {% endif %}

  {% if pageKey == 'films' or pageKey == 'home' %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {% for film in films.items %}
      {
        "@type": "VideoObject",
        "name": {{ film.title | dump | safe }},
        "description": {{ ((film.tags | join(", ")) + " — recorded in " + film.location) | dump | safe }},
        "thumbnailUrl": "https://img.youtube.com/vi/{{ film.videoId }}/maxresdefault.jpg",
        "uploadDate": "{{ film.date }}-01",
        "contentUrl": {{ film.url | dump | safe }},
        "embedUrl": "https://www.youtube.com/embed/{{ film.videoId }}",
        "publisher": {
          "@type": "MusicGroup",
          "@id": "https://josepbernad.com/#musician",
          "name": "Josep Bernad"
        }
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  </script>
  {% endif %}

  {% if pageKey == 'live' %}
  {% set upcomingEvents = live.upcoming | upcomingOnly %}
  {% if upcomingEvents.length %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {% for ev in upcomingEvents %}
      {% set evName = ev.event[currentLang] if ev.event[currentLang] else ev.event %}
      {% set hh = ev.time | replace("h", "") | trim %}
      {% set hhPadded = hh if hh|length == 2 else "0" + hh %}
      {
        "@type": "MusicEvent",
        "name": {{ evName | dump | safe }},
        "startDate": "{{ ev.date }}T{{ hhPadded }}:00:00+02:00",
        "eventStatus": "https://schema.org/EventScheduled",
        "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
        "location": {
          "@type": "Place",
          "name": {{ ev.venue[currentLang] | dump | safe }},
          "hasMap": {{ ev.map | dump | safe }}
        },
        "performer": {
          "@type": "MusicGroup",
          "@id": "https://josepbernad.com/#musician",
          "name": "Josep Bernad"
        },
        "organizer": {
          "@type": "Person",
          "name": "Josep Bernad",
          "url": "https://josepbernad.com"
        },
        "description": {{ (ev.description[currentLang] | striptags) | dump | safe }},
        "url": "https://josepbernad.com{{ page.url }}",
        "image": "https://josepbernad.com/images/og-image.jpg"
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  </script>
  {% endif %}
  {% endif %}

  {% if pageKey == 'about' %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    "mainEntity": {
      "@type": "Person",
      "name": "Josep Bernad",
      "url": "https://josepbernad.com{{ page.url }}",
      "image": "https://josepbernad.com/images/about.webp",
      "jobTitle": "Musician, DJ, Software Engineer",
      "description": {{ about[currentLang].hero.sub | striptags | dump | safe }},
      "homeLocation": { "@type": "Place", "name": "Barcelona, Spain" },
      "birthPlace": { "@type": "Place", "name": "Mallorca, Spain" },
      "performerIn": { "@id": "https://josepbernad.com/#musician" },
      "sameAs": [
        "https://www.instagram.com/djosepbernad/",
        "https://www.youtube.com/@JosepBernad",
        "https://open.spotify.com/artist/1f320LpftKzOM47I0RgMfJ",
        "https://soundcloud.com/djosepbernad",
        "https://www.linkedin.com/in/josepbernad/",
        "https://github.com/JosepBernad"
      ]
    }
  }
  </script>
  {% endif %}
</head>
<body>
  {% include "header.njk" %}

  <main class="content">
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}

  <script type="module" src="/js/main.js"></script>

  <!-- Analytics (GoatCounter - privacy-friendly, no cookies) -->
  <script data-goatcounter="https://josepbernad.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
</body>
</html>
