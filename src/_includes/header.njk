{# `pagePath` (language-prefix-stripped) is computed in base.njk and reused here for the switcher. #}

{% set navItems = [
  { id: 'films', path: '/films/', label: 'Films', i18n: 'nav.films' },
  { id: 'live', path: '/live/', label: 'Live', i18n: 'nav.live' },
  { id: 'about', path: '/about/', label: 'About', i18n: 'nav.about' },
  { id: 'contact', path: '/contact/', label: 'Contact', i18n: 'nav.contact' },
  { id: 'presskit', path: '/press-kit/', label: 'Press Kit', i18n: 'nav.presskit' }
] %}

<header class="site-header">
  <div class="site-header__bar">
    <div class="site-header__left">
      <div class="site-header__identity">
        <p class="header-line header-name header-name--logo"><a href="{{ urlLangPrefix }}/" class="header-name-link" aria-label="Josep Bernad"><svg class="header-name-logo" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 498" aria-hidden="true" focusable="false"><path fill="currentColor" stroke="currentColor" stroke-width="4" stroke-linejoin="round" d="m367.28 206.84q-25.5-24.47-71.45-32.48v-1.99c13.68-2.66 25.88-7.58 36.72-14.73 10.84-7.17 19.39-15.82 25.73-26q9.47-15.22 9.48-33.21 0.01-21.98-12.98-41.46-12.99-19.49-40.96-31.73-27.97-12.23-73.92-12.24h-1.79-6.39-155.81c-1.36 0-2.47 1.11-2.47 2.47v15.64c0 1.37 1.11 2.47 2.47 2.47h36.44q1.54 3.42 2.83 10.15 1.72 9.23 1.73 28.72v214.32q0.01 11.98-0.48 32.72-0.5 20.74-1.99 43.71c-1.03 15.32-2.51 29.64-4.5 42.97q-3.03 19.97-8 30.47c-2.32 4.32-5.34 7.99-8.99 10.99-3.69 2.99-8.67 4.5-15.01 4.5q-8.97-0.01-22.97-3.25-14-3.25-24.96-9.75-22.01 8.49-22.01 27.49 0.01 7.48 5.27 11.48 5.27 3.99 11.47 5.24c4.16 0.83 7.45 1.25 9.77 1.25 18.62 0 35.8-3.83 51.43-11.48 15.67-7.67 29.39-17.99 41.22-30.97 11.84-13 21.05-27.49 27.73-43.47q8.5-20.98 10.98-50.95c1.7-19.99 2.51-41.8 2.51-65.45v-231.29q-0.01-12.26 3.57-17.4h59.77c18.22 0.71 33.66 3.63 45.12 9.65q19.51 10.24 28.24 25.98 8.74 15.74 8.74 33.22-0.01 15.98-8.48 30.47-8.51 14.49-25.48 23.23c-9.86 5.07-37.6 7.81-45.86 8.41-1.29 0.09-2.28 1.17-2.28 2.46v15.31c0 1.27 0.98 2.33 2.25 2.45 14.61 1.39 27.88 3.25 38.37 6.1q23.99 6.49 36.98 16.97c8.67 6.99 14.64 14.99 17.99 23.99q4.98 13.49 4.98 28.98-0.01 28.97-21.2 48.2c-14.19 12.82-35.58 19.23-64.22 19.23h-15.15-37.44c-1.31 0-2.39 1.03-2.46 2.34q-0.42 7.69-0.99 14.99c-0.11 1.43 1.02 2.65 2.46 2.65h38.43 18.65q45.46 0.01 77.2-12.24 31.69-12.22 48.45-32.22 16.75-19.97 16.74-42.95 0.01-29.48-25.48-53.96z"/></svg></a></p>
      </div>

      <nav id="primary-nav" class="site-nav" aria-label="Primary">
        <ul>
          {% for item in navItems %}
          <li>
            <a href="{{ urlLangPrefix }}{{ item.path }}"
               class="site-nav__link{% if pageId == item.id %} active{% endif %}"
               {% if pageId == item.id %}aria-current="page"{% endif %}
               data-i18n="{{ item.i18n }}">{{ item.label }}</a>
          </li>
          {% endfor %}
        </ul>

        <div class="site-nav__controls" data-nosnippet>
          <div class="lang-switcher">
            <a href="{{ pagePath }}" class="lang-link{% if urlLang == 'en' %} active{% endif %}" hreflang="en" lang="en">EN</a>
            <a href="/ca{{ pagePath }}" class="lang-link{% if urlLang == 'ca' %} active{% endif %}" hreflang="ca" lang="ca">CA</a>
            <a href="/es{{ pagePath }}" class="lang-link{% if urlLang == 'es' %} active{% endif %}" hreflang="es" lang="es">ES</a>
          </div>
          <span class="header-divider" aria-hidden="true"></span>
          <button type="button" class="theme-toggle" aria-label="Switch to dark mode" aria-pressed="false">
            {% include "icons/sun.njk" %}
            {% include "icons/moon.njk" %}
          </button>
        </div>
      </nav>
    </div>

    <div class="site-header__controls">
      <div class="lang-switcher" data-nosnippet>
        <a href="{{ pagePath }}" class="lang-link{% if urlLang == 'en' %} active{% endif %}" hreflang="en" lang="en">EN</a>
        <a href="/ca{{ pagePath }}" class="lang-link{% if urlLang == 'ca' %} active{% endif %}" hreflang="ca" lang="ca">CA</a>
        <a href="/es{{ pagePath }}" class="lang-link{% if urlLang == 'es' %} active{% endif %}" hreflang="es" lang="es">ES</a>
      </div>

      <span class="header-divider" aria-hidden="true" data-nosnippet></span>

      <button type="button" class="theme-toggle" aria-label="Switch to dark mode" aria-pressed="false" data-nosnippet>
        {% include "icons/sun.njk" %}
        {% include "icons/moon.njk" %}
      </button>

      <button type="button" class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="primary-nav" data-nosnippet>
        {% include "icons/menu.njk" %}
        {% include "icons/close.njk" %}
      </button>
    </div>
  </div>
</header>
